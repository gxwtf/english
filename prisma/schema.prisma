// This is your Prisma schema file
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// 用户表 - 与广学账号系统关联
model User {
  id           Int             @id @default(autoincrement())
  userId       Int             @unique // 广学账号系统用户 ID
  userName     String          // 广学账号用户名
  admin        Int             @default(0)
  email        String?
  realName     String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  // 关联关系
  words          Word[]
  tagConfigs     TagConfig[]
  relatedWords   RelatedWord[]
  questions      QuestionQueue[]
}

// 单词表
model Word {
  id           Int             @id @default(autoincrement())
  userId       Int             // 所属用户 ID
  text         String          // 单词文本
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  // 关联关系
  user         User            @relation(fields: [userId], references: [userId], onDelete: Cascade)
  meanings     Meaning[]
  wordTags     WordTag[]

  // 唯一约束：同一用户不能有重复的单词
  @@unique([userId, text])
}

// 释义表
model Meaning {
  id        Int       @id @default(autoincrement())
  wordId    Int       // 所属单词 ID
  content   String    // 释义内容
  type      String    // 词性/类型
  sentence  String?   // 例句
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // 关联关系
  word Word @relation(fields: [wordId], references: [id], onDelete: Cascade)
}

// 题目生成状态
enum QuestionStatus {
  GENERATING  // AI 正在生成题目
  GENERATED   // 题目已生成完毕
  ANSWERED    // 用户已作答
  FAILED      // 生成失败，可重试
}

// AI 出题队列
model QuestionQueue {
  id              String          @id @default(cuid())
  userId          Int
  questionType    String          // 题目类型：'fill-blank' | 'translate'
  status          QuestionStatus  @default(GENERATING)
  questionContent Json?           // AI 生成的题目内容（生成完毕后写入）
  lastAnswer      Json?           // 上一次的作答情况
  wordIds         Int[]           // 生成时使用的单词 id 列表
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)
}

// 标签定义表（系统预定义的标签）
model Tag {
  id          Int       @id @default(autoincrement())
  name        String    @unique // 标签名称（唯一）
  colorId     String    @default("blue") // 颜色 ID
  description String?   // 标签描述
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // 关联关系
  wordTags WordTag[]
}

// 单词 - 标签关联表（多对多）
model WordTag {
  id        Int       @id @default(autoincrement())
  wordId    Int       // 单词 ID
  tagId     Int       // 标签 ID
  createdAt DateTime  @default(now())

  // 关联关系
  word Word  @relation(fields: [wordId], references: [id], onDelete: Cascade)
  tag  Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  // 唯一约束：同一单词不能有重复的标签
  @@unique([wordId, tagId])
}

// 关联单词（存储在单词本中与其他单词的关联关系）
model RelatedWord {
  id           Int       @id @default(autoincrement())
  userId       Int       // 所属用户 ID
  wordText     String    // 主单词文本
  relatedText  String    // 关联单词文本
  type         String    // 关联类型：'different_form' | 'easily_confused'
  createdAt    DateTime  @default(now())

  // 关联关系
  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  // 索引：通过主单词文本查找关联
  @@index([userId, wordText])
}

// 用户自定义标签配置
model TagConfig {
  id          Int       @id @default(autoincrement())
  userId      Int       // 所属用户 ID
  name        String    // 标签名称
  colorId     String    @default("blue") // 颜色 ID
  description String?   // 标签描述
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // 关联关系
  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  // 唯一约束：同一用户不能有重复的标签配置
  @@unique([userId, name])
}
