generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             Int               @id @default(autoincrement())
  userId         Int               @unique
  userName       String
  admin          Int               @default(0)
  email          String?
  realName       String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  questions      QuestionQueue[]
  relatedWords   RelatedWord[]
  tagConfigs     TagConfig[]
  words          Word[]
  writingEntries WritingEntry[]
}

model Word {
  id           Int       @id @default(autoincrement())
  userId       Int
  text         String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  relatedWords Json?
  meanings     Json[]
  user         User      @relation(fields: [userId], references: [userId], onDelete: Cascade)
  wordTags     WordTag[]

  @@unique([userId, text])
}

model QuestionQueue {
  id                 String         @id @default(cuid())
  userId             Int
  questionType       String
  status             QuestionStatus @default(GENERATING)
  questionContent    Json?
  lastAnswer         Json?
  wordIds            Int[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  gradingResult      Json?
  relatedWordEntries Json?
  user               User           @relation(fields: [userId], references: [userId], onDelete: Cascade)
}

model Tag {
  id               Int               @id @default(autoincrement())
  name             String            @unique
  colorId          String            @default("blue")
  description      String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  wordTags         WordTag[]
  writingEntryTags WritingEntryTag[]
}

model WordTag {
  id        Int      @id @default(autoincrement())
  wordId    Int
  tagId     Int
  createdAt DateTime @default(now())
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  word      Word     @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@unique([wordId, tagId])
}

model RelatedWord {
  id          Int      @id @default(autoincrement())
  userId      Int
  wordText    String
  relatedText String
  type        String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId, wordText])
}

model TagConfig {
  id          Int      @id @default(autoincrement())
  userId      Int
  name        String
  colorId     String   @default("blue")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([userId, name])
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model Word_meanings_backup_20260505 {
  id           Int?
  text         String?
  meanings_old String[]

  @@ignore
}

model migration_log {
  id             Int       @id @default(dbgenerated("nextval('_migration_log_id_seq'::regclass)"))
  migration_name String
  executed_at    DateTime? @default(now()) @db.Timestamp(6)
  backup_table   String?
  status         String?   @default("completed")

  @@map("_migration_log")
}

enum QuestionStatus {
  GENERATING
  GENERATED
  ANSWERED
  FAILED
  GRADING
  GRADING_FAILED
}

model WritingEntry {
  id        Int      @id @default(autoincrement())
  userId    Int
  content   String
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [userId], onDelete: Cascade)
  tags      WritingEntryTag[]

  @@index([userId])
}

model WritingEntryTag {
  id             Int           @id @default(autoincrement())
  writingEntryId Int
  tagId          Int
  createdAt      DateTime      @default(now())
  tag            Tag           @relation(fields: [tagId], references: [id], onDelete: Cascade)
  writingEntry   WritingEntry  @relation(fields: [writingEntryId], references: [id], onDelete: Cascade)

  @@unique([writingEntryId, tagId])
}
