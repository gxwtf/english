# 数据库连接
# 格式：postgresql://用户名:密码@主机:端口/数据库名
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/gxwtf_english"

# SSO 配置
GXACCOUNT_URL="https://account.gxwtf.cn"

# iron-session 加密密码
# 必须至少32位字符，生产环境必须更换为强密码且不能泄露
# 建议使用：openssl rand -base64 32 或 node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET_COOKIE_PASSWORD="change-this-to-your-own-32-char-secret-password"

# API 认证密钥
# 用于作文积累查询 API 的认证
# 在服务器上，该字段的值与服务器密码相同
SECRET_API_KEY="change-this-to-your-secure-api-key-in-production"

# AI 模型配置（LLM）
# 用于文本生成功能
LLM_CONFIGS='[
  {
    "name": "your-model-name",
    "model": "model-id",
    "apiKey": "your-ai-api-key-here",
    "apiBase": "https://your-api-base-url/v1"
  }
]'

# AI 模型配置（图像）
# 用于图像生成功能
LLM_IMAGE_CONFIGS='[
  {
    "name": "your-image-model-name",
    "model": "image-model-id",
    "apiKey": "your-image-api-key-here",
    "apiBase": "https://your-image-api-base-url/v1"
  }
]'

# ========================================
# 生产环境部署注意事项
# ========================================
#
# 1. 必须更换以下密钥：
#    - SECRET_COOKIE_PASSWORD（至少32位强密码）
#    - SECRET_API_KEY（API认证密钥）
#    - DATABASE_URL中的数据库密码
#    - LLM_CONFIGS和LLM_IMAGE_CONFIGS中的apiKey
#
# 2. 安全建议：
#    - 使用HTTPS部署
#    - 定期更换API密钥
#    - 不要将.env文件上传到公开仓库
#    - 使用环境变量管理工具（如Vault、AWS Secrets Manager）
#
# 3. 密钥生成方法：
#    SECRET_COOKIE_PASSWORD: openssl rand -base64 32
#    SECRET_API_KEY: openssl rand -base64 32
#
# ========================================