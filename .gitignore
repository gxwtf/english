# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# 词典文件
src/dict/*

# prisma
/src/generated/prisma

# PaddleOCR 服务（源码纳入 git，仅排除缓存和编译产物）
/paddleocr-service/__pycache__/
/paddleocr-service/.paddleocr_cache/
/paddleocr-service/venv/

# PaddleOCR 模型缓存（旧位置，已迁移到 paddleocr-service/）
/.paddleocr_cache/

# package-lock.json
package-lock.json

# 数据库同步脚本（包含敏感信息）
scripts/sync-db-from-remote.ts
scripts/sync-user-data.mjs