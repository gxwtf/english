generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int             @id @default(autoincrement())
  userId       Int             @unique
  userName     String
  admin        Int             @default(0)
  email        String?
  realName     String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  questions    QuestionQueue[]
  relatedWords RelatedWord[]
  tagConfigs   TagConfig[]
  words        Word[]
}

model Word {
  id           Int       @id @default(autoincrement())
  userId       Int
  text         String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  meanings     String[]
  relatedWords Json?
  user         User      @relation(fields: [userId], references: [userId], onDelete: Cascade)
  wordTags     WordTag[]

  @@unique([userId, text])
}

model QuestionQueue {
  id              String         @id @default(cuid())
  userId          Int
  questionType    String
  status          QuestionStatus @default(GENERATING)
  questionContent Json?
  gradingResult  Json?
  lastAnswer      Json?
  wordIds         Int[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  user            User           @relation(fields: [userId], references: [userId], onDelete: Cascade)
}

model Tag {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  colorId     String    @default("blue")
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  wordTags    WordTag[]
}

model WordTag {
  id        Int      @id @default(autoincrement())
  wordId    Int
  tagId     Int
  createdAt DateTime @default(now())
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  word      Word     @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@unique([wordId, tagId])
}

model RelatedWord {
  id          Int      @id @default(autoincrement())
  userId      Int
  wordText    String
  relatedText String
  type        String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId, wordText])
}

model TagConfig {
  id          Int      @id @default(autoincrement())
  userId      Int
  name        String
  colorId     String   @default("blue")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([userId, name])
}

enum QuestionStatus {
  GENERATING
  GENERATED
  ANSWERED
  FAILED
  GRADING
  GRADING_FAILED
}
